# BotFather'dan olingan bot tokeningiz
BOT_TOKEN=123456789:AAExampleTokenHere

# Render'da deploy qilingandan keyin shu xizmatning ochiq URL manzili
# Masalan: https://talim-talaba-bot.onrender.com
WEBHOOK_URL=https://talim-talaba-bot.onrender.com

# Mini ilova (index.html) joylashtirilgan URL manzil
# Buni o'zingiz boshqa joyga (Netlify, GitHub Pages, Render Static Site va h.k.) joylashtirib,
# shu yerga shu manzilni yozasiz. Https bo'lishi shart.
MINI_APP_URL=https://example.com/talim-talaba-miniapp/

# Mini ilovadagi "Fikr-mulohaza" formasidan kelgan xabarlar shu chatga yuboriladi.
# Buni topish uchun: botni deploy qilgach, botga shaxsiy chatda /id deb yozing —
# bot sizga shu qatorga qo'yiladigan raqamni jo'natadi.
ADMIN_CHAT_ID=7924605766

# AI javoblar uchun (Google AI Studio'dan olinadi, bepul tarif mavjud)
GEMINI_API_KEY=

# Gemini ishlamasa zaxira sifatida ishlatiladi (console.groq.com'dan olinadi, bepul tarif mavjud)
GROQ_API_KEY=

# Render avtomatik beradi, lokal test uchun ixtiyoriy
PORT=3000
